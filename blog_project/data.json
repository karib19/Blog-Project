    "model": "blog.post",
    "pk": 1,
    "fields": {
      "title": "The dirty side of politics",
      "slug": "the-dirty-side-of-politics",
      "excerpt": "",
      "content": "Dirty politics\" refers to the use of unprincipled, dishonest, and often unethical tactics to gain power or achieve specific, sometimes immoral, ends. This dark side includes illicit campaign financing, voter manipulation, negative campaigning, and the use of misinformation. Key drivers often involve Machiavellianism and the \"Dark Triad\" personality traits.",
      "featured_image": "",
      "author": 2,
      "category": 1,
      "status": "published",
      "views": 0,
