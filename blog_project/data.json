  {
    "model": "blog.post",
    "pk": 6,
    "fields": {
      "title": "FIFA WORLD CUP 2026",
      "slug": "fifa-world-cup-2026",
      "excerpt": "",
      "content": "The 2026 FIFA World Cup is currently underway in North America, marking the largest, most expansive edition in football history.A Tournament of Historic FirstsThe 23rd edition of the global showpiece introduces structural transformations to the traditional format:Three Co-Hosts: Matches are being staged across 16 cities spanning Canada, Mexico, and the United States.Expanded Field: The tournament field has increased from 32 to 48 national teams.Massive Schedule: A record-breaking 104 total fixtures are taking place over a 39-day window.New Knockout Phase: The top two teams from 12 groups, alongside the eight best third-place finishers, will advance to a brand-new Round of 32 knockout stage.",
      "featured_image": "",
      "author": 6,
      "category": 2,
      "status": "published",
      "views": 0,
      "reading_time": 1,
      "is_featured": false,
