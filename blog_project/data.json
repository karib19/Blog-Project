  {
    "model": "blog.post",
    "pk": 4,
    "fields": {
      "title": "The New Bangladesh",
      "slug": "the-new-bangladesh",
      "excerpt": "",
      "content": "Today, Bangladesh begins a new journey. After over 18 months since the mass uprising, the long-awaited election has finally been held, opening up the path for a democratic transition. After any election, it is natural that one party will form the government and another will be the opposition. The question for now is whether a large section of the voters have participated in the election, and whether the electoral process has been relatively free from external interference or disturbance. Going by initial estimates, the election has certainly passed the test.",
      "featured_image": "",
      "author": 4,
      "category": 1,
      "status": "published",
